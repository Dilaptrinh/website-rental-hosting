
# DATABASE CONFIGURATION (MySQL)

MYSQL_ROOT_PASSWORD=your_mysql_root_password_here
MYSQL_DATABASE=web_rental


# SYSTEM DOMAIN CONFIGURATION

APP_BASE_URL=domain-name
APP_FRONTEND_URL=domain-name


# SECURITY & AUTHENTICATION CONFIGURATION

# Mã JWT Secret phải đủ 256-bit (tối thiểu 32 ký tự)
JWT_SECRET=your_256_bit_secret_key_here_must_be_at_least_256_bits_long
SUPER_ADMIN_EMAIL=superadmin@web-rental.com
SUPER_ADMIN_PASSWORD=SuperAdmin@123


# GOOGLE OAUTH2 CREDENTIALS

GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here


# MOMO PAYMENT GATEWAY (SANDBOX)

MOMO_PARTNER_CODE=your_momo_partner_code_here
MOMO_ACCESS_KEY=your_momo_access_key_here
MOMO_SECRET_KEY=your_momo_secret_key_here